{
  "name": "mnemonic",
  "image": "mcr.microsoft.com/devcontainers/base:noble",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/node:2": {
      "version": "24"
    }
  },

  "postCreateCommand": "curl -fsSL https://ollama.com/install.sh | sh && npm ci",
  "postStartCommand": "ollama serve &",
  "postAttachCommand": "ollama pull nomic-embed-text-v2-moe",

  "customizations": {
    "vscode": {
      "settings": {
        "typescript.tsdk": "node_modules/typescript/lib"
      },
      "extensions": [
        "vitest.explorer",
        "davidanson.vscode-markdownlint"
      ]
    }
  }
}
