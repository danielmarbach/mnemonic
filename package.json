{
  "name": "@danielmarbach/mnemonic-mcp",
  "version": "0.36.1",
  "description": "A local MCP memory server backed by markdown + JSON files, synced via git",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielmarbach/mnemonic.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "build",
    "skills",
    "scripts/install-skills.mjs",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "mnemonic": "build/index.js",
    "mnemonic-install-skills": "scripts/install-skills.mjs"
  },
  "scripts": {
    "build": "npm run typecheck && tsc && chmod 755 build/index.js",
    "build:clean": "tsc --build --clean && npm run build",
    "build:fast": "tsc && chmod 755 build/index.js",
    "dev": "tsc --watch",
    "mcp:local": "./scripts/mcp-local.sh",
    "prepack": "npm run build",
    "start": "node build/index.js",
    "dogfood:isolated": "MNEMONIC_ENTRYPOINT=build/index.js node scripts/run-dogfood-packs.mjs --isolated",
    "verify:release": "npm run build && npm test && npm run dogfood:isolated",
    "skills:install": "node scripts/install-skills.mjs --target all --mode copy",
    "skills:update": "node scripts/install-skills.mjs --target all --mode copy --update",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "node scripts/prepare.mjs"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.1",
    "gray-matter": "^4.0.3",
    "markdownlint": "^0.41.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "simple-git": "^3.27.0",
    "unified": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "@eslint/js": "10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "lint-staged": "^17.0.5",
    "prettier": "3.9.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "7.0.2",
    "typescript-eslint": "8.65.0",
    "vitest": "^4.0.18"
  }
}
