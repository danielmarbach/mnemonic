    "description": "Use after you have identified the exact memories to connect.

Use this when:
- A newly stored or updated note meaningfully connects to another note
- One note explains, exemplifies, supersedes, or closely relates to another

Do not use this when:
- The connection is weak or speculative
- You need to remove a relationship rather than add one

Returns: both ids, relationship type.

Writable attachments: can relate notes in writable attached vaults.

[mutating: modifies both notes, git commits, may push]

Typical next step:
- Use \`get\` on both notes to verify the relationship context reads well.",
    "inputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "properties": {
        "bidirectional": {
          "default": true,
          "description": "Add relationship in both directions (default: true)",
          "type": "boolean",
        },
        "cwd": {
          "description": "Absolute path of the project working directory. Required for project-scoped routing, vault selection, and search boosting.",
          "type": "string",
        },
        "fromId": {
          "description": "Source memory id",
          "type": "string",
        },
        "toId": {
          "description": "Target memory id",
          "type": "string",
        },
        "type": {
          "default": "related-to",
          "description": "Relationship type: 'related-to' (same topic), 'explains' (clarifies why), 'example-of' (instance of pattern), 'supersedes' (replaces), 'derives-from' (derived artifact), 'follows' (sequence order)",
          "enum": [
            "related-to",
            "explains",
            "example-of",
            "supersedes",
            "derives-from",
            "follows",
          ],
          "type": "string",
        },
      },
      "required": [
        "fromId",
        "toId",
      ],
      "type": "object",
    },
    "name": "relate",
    "outputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "additionalProperties": false,
      "properties": {
        "action": {
          "enum": [
            "related",
            "unrelated",
          ],
          "type": "string",
        },
        "bidirectional": {
          "type": "boolean",
        },
        "fromId": {
          "type": "string",
        },
        "notesModified": {
          "items": {
            "type": "string",
          },
          "type": "array",
        },
        "retry": {
          "additionalProperties": false,
          "properties": {
            "attemptedCommit": {
              "additionalProperties": false,
              "properties": {
                "body": {
                  "type": "string",
                },
                "cwd": {
                  "type": "string",
                },
                "error": {
                  "type": "string",
                },
                "files": {
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
                "operation": {
                  "enum": [
                    "add",
                    "commit",
                  ],
                  "type": "string",
                },
                "subject": {
                  "type": "string",
                },
                "vault": {
                  "pattern": "^main-vault$|^project-vault$|^sub-vault:\\.mnemonic-.+$|^attached:[a-z0-9][-a-z0-9]*\\/\\.mnemonic(-.+)?$",
                  "type": "string",
                },
              },
              "required": [
                "subject",
                "files",
                "vault",
                "error",
              ],
              "type": "object",
            },
            "instructions": {
              "additionalProperties": false,
              "properties": {
                "forbidInferenceFromHistory": {
                  "type": "boolean",
                },
                "forbidInferenceFromTitleOrSummary": {
                  "type": "boolean",
                },
                "forbidParallelSameVaultRetries": {
                  "type": "boolean",
                },
                "preferToolReconciliation": {
                  "type": "boolean",
                },
                "rerunSameToolCallSerially": {
                  "type": "boolean",
                },
                "sourceOfTruth": {
                  "enum": [
                    "attemptedCommit",
                    "tool-response",
                  ],
                  "type": "string",
                },
                "useExactBody": {
                  "type": "boolean",
                },
                "useExactFiles": {
                  "type": "boolean",
                },
                "useExactSubject": {
                  "type": "boolean",
                },
              },
              "required": [
