                        "title",
                        "updatedAt",
                      ],
                      "type": "object",
                    },
                    "type": "array",
                  },
                  "totalDirectRelations": {
                    "type": "number",
                  },
                  "truncated": {
                    "type": "boolean",
                  },
                },
                "required": [
