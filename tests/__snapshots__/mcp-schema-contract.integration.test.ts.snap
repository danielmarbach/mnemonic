          "type": "string",
        },
        "ids": {
          "description": "One or more memory ids to fetch",
          "items": {
            "pattern": "^[a-zA-Z0-9_-]+$",
            "type": "string",
          },
          "minItems": 1,
          "type": "array",
        },
        "includeRelationships": {
          "default": false,
          "description": "Include bounded direct relationship previews (1-hop expansion, max 3 shown)",
          "type": "boolean",
        },
      },
      "required": [
        "ids",
      ],
      "type": "object",
    },
