                "useExactSubject",
                "useExactBody",
                "useExactFiles",
                "forbidInferenceFromHistory",
                "forbidInferenceFromTitleOrSummary",
                "forbidParallelSameVaultRetries",
                "preferToolReconciliation",
                "rerunSameToolCallSerially",
              ],
              "type": "object",
            },
            "mutationApplied": {
              "type": "boolean",
            },
            "rationale": {
              "type": "string",
