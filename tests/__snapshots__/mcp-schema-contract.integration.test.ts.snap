  {
    "annotations": {
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false,
      "readOnlyHint": true,
    },
    "description": "Use this when:
- You want to browse what exists for a project or globally
- You want a deterministic filtered list rather than a semantic search
- You are checking inventory before creating, updating, or consolidating notes

Do not use this when:
- You want topic-based semantic search; use \`recall\`
- You already know the exact id; use \`get\`

Returns: matching memories with ids, titles, scope/storage context, metadata.

Typical next step:
- Use \`get\` for exact inspection or \`update\` / \`consolidate\` for cleanup.",
    "inputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "properties": {
        "cwd": {
          "description": "Absolute path of the project working directory. Required for project-scoped routing, vault selection, and search boosting.",
          "type": "string",
        },
        "includePreview": {
          "default": false,
          "description": "Include a short content preview for each note",
          "type": "boolean",
        },
        "includeRelations": {
          "default": false,
          "description": "Include related memory ids and relationship types",
          "type": "boolean",
        },
        "includeStorage": {
          "default": false,
          "description": "Show which vault each note is stored in",
          "type": "boolean",
        },
        "includeUpdated": {
          "default": false,
          "description": "Include last-updated timestamp for each note",
          "type": "boolean",
        },
        "scope": {
          "default": "all",
          "description": "'project' = this project's memories and attached vault notes; 'global' = only unscoped memories (main/global storage); 'all' = everything visible from this context (default)",
          "enum": [
            "project",
            "global",
            "all",
          ],
          "type": "string",
        },
        "storedIn": {
          "default": "any",
          "description": "Storage-label filter. Use \`main-vault\` for main/global storage. Use \`project-vault\` as the broad filter for any project vault, including sub-vaults. Use \`attached\` for notes from attached external repositories only. Results may still return a more specific label such as \`sub-vault:.mnemonic-lib\`.",
          "enum": [
            "project-vault",
            "main-vault",
            "any",
            "attached",
          ],
          "type": "string",
        },
        "tags": {
          "description": "Filter to notes matching all of these tags.",
          "items": {
            "type": "string",
          },
          "type": "array",
        },
      },
      "type": "object",
    },
    "name": "list",
    "outputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "listed",
          "type": "string",
        },
        "count": {
          "type": "number",
        },
        "notes": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "hasRelated": {
                "type": "boolean",
              },
              "id": {
                "type": "string",
              },
              "lifecycle": {
                "enum": [
                  "temporary",
                  "permanent",
                ],
                "type": "string",
              },
              "project": {
                "additionalProperties": false,
                "properties": {
                  "id": {
                    "type": "string",
                  },
                  "name": {
                    "type": "string",
                  },
                },
                "required": [
                  "id",
                  "name",
                ],
                "type": "object",
              },
              "role": {
                "enum": [
                  "summary",
                  "decision",
                  "plan",
                  "context",
                  "reference",
                  "research",
                  "review",
                ],
                "type": "string",
              },
              "tags": {
