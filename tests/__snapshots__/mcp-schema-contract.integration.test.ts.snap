                "forbidInferenceFromHistory",
                "forbidInferenceFromTitleOrSummary",
                "forbidParallelSameVaultRetries",
                "preferToolReconciliation",
                "rerunSameToolCallSerially",
              ],
              "type": "object",
            },
            "mutationApplied": {
              "type": "boolean",
            },
            "rationale": {
              "type": "string",
            },
            "recovery": {
              "additionalProperties": false,
              "properties": {
                "allowed": {
                  "type": "boolean",
                },
                "kind": {
                  "enum": [
                    "manual-exact-git-recovery",
                    "rerun-tool-call-serial",
                    "no-manual-recovery",
                  ],
                  "type": "string",
                },
                "reason": {
                  "type": "string",
                },
              },
              "required": [
                "kind",
                "allowed",
                "reason",
              ],
              "type": "object",
            },
            "retrySafe": {
              "type": "boolean",
            },
          },
          "required": [
            "recovery",
            "attemptedCommit",
            "mutationApplied",
            "retrySafe",
            "rationale",
            "instructions",
          ],
          "type": "object",
        },
        "warnings": {
          "items": {
            "type": "string",
          },
          "type": "array",
        },
      },
      "required": [
        "action",
        "project",
        "attachment",
      ],
      "type": "object",
    },
    "title": "Add Attachment",
  },
  {
    "annotations": {
      "destructiveHint": true,
      "idempotentHint": false,
      "openWorldHint": true,
      "readOnlyHint": false,
    },
    "description": "Use after \`recall\`, \`list\`, or \`memory_graph\` shows overlap that should be merged or cleaned up.

Use this when:
- Multiple notes cover the same decision, fix, or concept
- One memory supersedes several older fragments

Do not use this when:
- You only need a small edit to one note; use \`update\`
- You only want to connect notes; use \`relate\`

Returns: canonical memory id, source ids, relationships, persistence status, classification (lineage/duplicate-pressure/unique-evidence-risk/supersession-pressure), maintenance warnings.

[mutating: creates/updates canonical note, modifies/removes sources per mode, git commits, may push]

Typical next step:
- Use \`get\` to inspect the canonical note and \`recall\` to confirm duplication is reduced.
- Evidence defaults on for consolidate analysis strategies and execute-merge (lifecycle, risk, warnings).",
    "inputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "properties": {
        "allowProtectedBranch": {
          "description": "One-time override for protected branch checks. When true, consolidate can commit on a protected branch without changing project policy.",
          "type": "boolean",
        },
        "cwd": {
          "description": "Absolute path of the project working directory. Required for project-scoped routing, vault selection, and search boosting.",
          "type": "string",
        },
        "evidence": {
          "description": "Confidence signals for analysis strategies and execute-merge (lifecycle, risk, warnings). Default true for safety.",
          "type": "boolean",
        },
        "mergePlan": {
          "description": "Required for 'execute-merge' strategy. Get sourceIds from 'suggest-merges' output.",
          "properties": {
            "content": {
              "description": "Custom body for the consolidated note — distill durable knowledge rather than dumping all source content verbatim",
              "maxLength": 100000,
              "type": "string",
            },
            "description": {
              "description": "Context explaining the consolidation rationale (stored in the note)",
              "type": "string",
            },
            "sourceIds": {
              "description": "Ids of notes to merge into one consolidated note",
              "items": {
                "type": "string",
              },
              "minItems": 2,
              "type": "array",
            },
            "summary": {
              "description": "Git commit summary only. Imperative mood, concise, and focused on why the change matters.",
              "type": "string",
            },
            "tags": {
              "description": "Optional tags for later filtering. Use a small number of stable, meaningful tags.",
              "items": {
                "type": "string",
              },
              "type": "array",
            },
            "targetTitle": {
              "description": "Title for the consolidated note",
              "type": "string",
            },
          },
          "required": [
            "sourceIds",
            "targetTitle",
          ],
          "type": "object",
        },
        "mode": {
          "description": "Override the project's default: 'supersedes' preserves history, 'delete' removes sources immediately",
          "enum": [
            "supersedes",
            "delete",
          ],
          "type": "string",
        },
        "strategy": {
          "description": "What to do: 'dry-run' = full analysis without changes, 'detect-duplicates' = find similar pairs, 'find-clusters' = group by theme and relationships, 'suggest-merges' = actionable merge recommendations, 'execute-merge' = perform a merge (requires mergePlan), 'prune-superseded' = delete notes marked as superseded. Use \`evidence: true\` on analysis strategies for trust/risk signals.",
          "enum": [
            "detect-duplicates",
            "find-clusters",
            "suggest-merges",
            "execute-merge",
            "prune-superseded",
            "dry-run",
          ],
          "type": "string",
        },
        "threshold": {
          "default": 0.85,
          "description": "Cosine similarity threshold for duplicate detection (0.85 default)",
          "maximum": 1,
          "minimum": 0,
          "type": "number",
        },
      },
      "required": [
        "strategy",
      ],
      "type": "object",
    },
    "name": "consolidate",
