  {
    "annotations": {
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": true,
      "readOnlyHint": true,
    },
    "description": "Supports opt-in temporal mode (\`mode: "temporal"\`) for git-backed history and workflow mode (\`mode: "workflow"\`) for RPIR chain reconstruction.

Use this when:
- You know the topic but not the exact memory id
- Starting a session and want relevant prior context
- Checking whether a memory already exists before creating another
- You want to inspect how a note evolved over time

Do not use this when:
- You already know the exact id; use \`get\`
- You just want to browse by tags or scope; use \`list\`

Returns: ranked matches (id, title, score, vault, tags, lifecycle, updatedAt), 1-hop relationship previews on top results, temporal history (mode: temporal), retrieval evidence (evidence: compact), diagnostics: recallScopeNoteCount, diversity, retrievalCoverage, signalStrength.

Typical next step:
- Use \`get\`, \`update\`, \`relate\`, or \`consolidate\` based on the results.",
    "inputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "properties": {
        "cwd": {
          "description": "Absolute path of the project working directory. Required for project-scoped routing, vault selection, and search boosting.",
          "type": "string",
        },
        "evidence": {
          "description": "Optional retrieval rationale. Omit for default output; use \`compact\` for bounded rank and lineage signals.",
          "enum": [
            "compact",
          ],
          "type": "string",
        },
        "lifecycle": {
          "description": "Filter results by lifecycle. Useful for recovering working-state with \`lifecycle: temporary\` after \`project_memory_summary\` orientation.",
          "enum": [
            "temporary",
            "permanent",
          ],
          "type": "string",
        },
        "limit": {
          "default": 5,
          "maximum": 20,
          "minimum": 1,
          "type": "integer",
        },
        "minSimilarity": {
          "default": 0.3,
          "maximum": 1,
          "minimum": 0,
          "type": "number",
        },
        "mode": {
          "default": "default",
          "description": "Use \`temporal\` for compact git-backed history, or \`workflow\` for RPIR-oriented chain reconstruction.",
          "enum": [
            "default",
            "temporal",
            "workflow",
          ],
          "type": "string",
        },
        "query": {
          "description": "Natural-language search query describing the topic, decision, bug, preference, or context you want to find.",
          "type": "string",
        },
        "scope": {
          "default": "all",
          "description": "'project' = this project's memories and attached vault notes, 'global' = only unscoped memories (main/global storage), 'all' = both, with project notes boosted (default)",
          "enum": [
            "project",
            "global",
            "all",
          ],
          "type": "string",
        },
        "tags": {
          "description": "Filter results to notes with all of these tags.",
          "items": {
            "type": "string",
          },
          "type": "array",
        },
        "verbose": {
          "default": false,
          "description": "Only meaningful with \`mode: "temporal"\`. Adds richer stats-based history context without returning raw diffs.",
          "type": "boolean",
        },
      },
      "required": [
        "query",
      ],
      "type": "object",
    },
    "name": "recall",
    "outputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "recalled",
          "type": "string",
        },
        "diversity": {
          "additionalProperties": false,
          "description": "Diversity metrics: gauge whether results span enough perspectives",
          "properties": {
            "lifecycleMix": {
              "additionalProperties": {
                "type": "number",
              },
              "description": "Count of each NoteLifecycle present in selected results",
              "propertyNames": {
                "type": "string",
              },
              "type": "object",
            },
            "roleMix": {
              "additionalProperties": {
                "type": "number",
              },
              "description": "Count of each NoteRole present in selected results",
              "propertyNames": {
                "type": "string",
              },
              "type": "object",
            },
            "themeCount": {
              "description": "Unique tag count across selected results",
              "maximum": 9007199254740991,
              "minimum": 0,
              "type": "integer",
            },
          },
          "required": [
            "themeCount",
            "roleMix",
            "lifecycleMix",
          ],
          "type": "object",
        },
        "query": {
          "type": "string",
        },
        "recallScopeNoteCount": {
          "description": "Total notes visible across all vaults for this recall scope. Use to decide whether to increase limit for small vaults.",
          "maximum": 9007199254740991,
          "minimum": 0,
          "type": "integer",
        },
        "results": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "boosted": {
                "type": "number",
              },
              "confidence": {
                "enum": [
                  "high",
                  "medium",
                  "low",
                ],
                "type": "string",
              },
              "history": {
                "items": {
                  "additionalProperties": false,
                  "properties": {
                    "changeCategory": {
                      "enum": [
                        "create",
                        "refine",
                        "expand",
                        "clarify",
                        "connect",
                        "restructure",
                        "reverse",
                        "unknown",
                      ],
                      "type": "string",
                    },
                    "changeDescription": {
                      "type": "string",
                    },
                    "commitHash": {
                      "type": "string",
                    },
                    "message": {
                      "type": "string",
                    },
                    "stats": {
                      "additionalProperties": false,
                      "properties": {
                        "additions": {
                          "type": "number",
                        },
                        "changeType": {
                          "enum": [
                            "metadata-only change",
                            "minor edit",
                            "substantial update",
                          ],
                          "type": "string",
                        },
                        "deletions": {
                          "type": "number",
                        },
                        "filesChanged": {
                          "type": "number",
                        },
                      },
                      "required": [
                        "additions",
                        "deletions",
                        "filesChanged",
                        "changeType",
                      ],
                      "type": "object",
                    },
                    "summary": {
                      "type": "string",
                    },
                    "timestamp": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "commitHash",
                    "timestamp",
                    "message",
                  ],
                  "type": "object",
                },
                "type": "array",
              },
              "historySummary": {
                "type": "string",
              },
              "id": {
                "type": "string",
              },
              "lifecycle": {
                "enum": [
                  "temporary",
                  "permanent",
                ],
                "type": "string",
              },
              "project": {
                "additionalProperties": false,
                "properties": {
                  "id": {
                    "type": "string",
                  },
                  "name": {
                    "type": "string",
                  },
                },
                "required": [
                  "id",
                  "name",
                ],
                "type": "object",
              },
              "provenance": {
                "additionalProperties": false,
                "properties": {
                  "lastCommitHash": {
                    "type": "string",
                  },
                  "lastCommitMessage": {
                    "type": "string",
                  },
                  "lastUpdatedAt": {
                    "type": "string",
                  },
                  "recentlyChanged": {
                    "type": "boolean",
                  },
                },
                "required": [
                  "lastUpdatedAt",
                  "lastCommitHash",
                  "lastCommitMessage",
                  "recentlyChanged",
                ],
                "type": "object",
              },
              "relationships": {
                "additionalProperties": false,
                "properties": {
                  "shown": {
                    "items": {
                      "additionalProperties": false,
                      "properties": {
                        "confidence": {
                          "enum": [
                            "high",
                            "medium",
                            "low",
                          ],
                          "type": "string",
                        },
                        "id": {
                          "type": "string",
                        },
                        "projectId": {
                          "type": "string",
                        },
                        "relationType": {
                          "enum": [
                            "related-to",
                            "explains",
                            "example-of",
                            "supersedes",
                            "derives-from",
                            "follows",
                          ],
                          "type": "string",
                        },
                        "theme": {
                          "type": "string",
                        },
                        "title": {
                          "type": "string",
                        },
                        "updatedAt": {
                          "type": "string",
                        },
                      },
                      "required": [
                        "id",
                        "title",
                        "updatedAt",
                      ],
                      "type": "object",
                    },
                    "type": "array",
                  },
                  "totalDirectRelations": {
                    "type": "number",
                  },
                  "truncated": {
                    "type": "boolean",
                  },
                },
                "required": [
                  "totalDirectRelations",
                  "shown",
                  "truncated",
                ],
                "type": "object",
              },
              "retrievalEvidence": {
                "additionalProperties": false,
                "properties": {
                  "channels": {
                    "items": {
                      "enum": [
                        "semantic",
                        "lexical",
                        "graph-rank",
                        "temporal-boost",
                        "canonical",
                        "rescue",
                      ],
                      "type": "string",
                    },
                    "type": "array",
                  },
                  "freshness": {
                    "enum": [
                      "today",
                      "thisWeek",
                      "thisMonth",
                      "older",
                    ],
                    "type": "string",
                  },
                  "projectRelevant": {
                    "type": "boolean",
                  },
                  "rankBand": {
                    "enum": [
                      "top3",
                      "top10",
                      "lower",
                    ],
                    "type": "string",
                  },
                  "superseded": {
                    "type": "boolean",
                  },
                  "supersededBy": {
                    "type": "string",
                  },
                  "supersededCount": {
                    "maximum": 9007199254740991,
                    "minimum": -9007199254740991,
                    "type": "integer",
                  },
                },
                "required": [
                  "channels",
                  "rankBand",
                  "projectRelevant",
                  "freshness",
                  "superseded",
                ],
                "type": "object",
              },
              "role": {
                "enum": [
                  "summary",
                  "decision",
                  "plan",
                  "context",
                  "reference",
                  "research",
                  "review",
                ],
                "type": "string",
              },
              "score": {
                "type": "number",
              },
              "signalStrength": {
                "description": "Composite quality signal (0-0.50). Higher = more structural support from role, centrality, lifecycle, and recency. Use alongside confidence.",
                "minimum": 0,
                "type": "number",
              },
              "tags": {
                "items": {
                  "type": "string",
                },
                "type": "array",
              },
              "title": {
                "type": "string",
              },
              "updatedAt": {
                "type": "string",
              },
              "vault": {
                "pattern": "^main-vault$|^project-vault$|^sub-vault:\\.mnemonic-.+$|^attached:[a-z0-9][-a-z0-9]*\\/\\.mnemonic(-.+)?$",
                "type": "string",
              },
            },
            "required": [
              "id",
              "title",
              "score",
              "boosted",
              "vault",
              "tags",
              "lifecycle",
              "updatedAt",
            ],
            "type": "object",
          },
          "type": "array",
        },
        "retrievalCoverage": {
          "additionalProperties": false,
          "description": "How well results cover the project's most important notes. Only present when project context is available.",
          "properties": {
            "anchorsInResults": {
              "description": "Number of high-priority anchors found in results",
              "maximum": 9007199254740991,
              "minimum": 0,
              "type": "integer",
            },
            "fraction": {
              "description": "Fraction of high-priority anchors present in results (0 when no anchors exist)",
              "maximum": 1,
              "minimum": 0,
              "type": "number",
            },
            "highPriorityAnchorsTotal": {
              "description": "Total high-priority anchors in the project vault",
              "maximum": 9007199254740991,
              "minimum": 0,
              "type": "integer",
            },
            "missingAnchors": {
              "description": "Up to 5 high-priority anchors not in results, for follow-up recall",
              "items": {
                "additionalProperties": false,
                "properties": {
                  "id": {
                    "type": "string",
                  },
                  "title": {
                    "type": "string",
                  },
                },
                "required": [
                  "id",
                  "title",
                ],
                "type": "object",
              },
              "type": "array",
            },
          },
          "required": [
            "anchorsInResults",
            "highPriorityAnchorsTotal",
            "fraction",
            "missingAnchors",
          ],
          "type": "object",
        },
        "scope": {
          "enum": [
            "project",
            "global",
            "all",
          ],
          "type": "string",
        },
      },
      "required": [
        "action",
        "query",
        "scope",
        "results",
      ],
      "type": "object",
    },
    "title": "Recall",
  },
  {
    "annotations": {
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false,
      "readOnlyHint": true,
    },
    "description": "Use this when:
- You want to see what changed most recently
- You are resuming work and want a quick chronological view

Do not use this when:
- You need topic-based search; use \`recall\`
- You need a tag/scope inventory; use \`list\`

Returns: recently updated memories with ids, timestamps, storage labels, metadata.

Typical next step:
- Use \`get\` for exact inspection or \`update\` to continue refining a recent note.",
    "inputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "properties": {
        "cwd": {
          "description": "Absolute path of the project working directory. Required for project-scoped routing, vault selection, and search boosting.",
          "type": "string",
        },
        "includePreview": {
          "default": true,
          "type": "boolean",
        },
        "includeStorage": {
          "default": true,
          "type": "boolean",
        },
        "lifecycle": {
          "description": "Filter results by lifecycle. Useful for recovering working-state with \`lifecycle: temporary\` after \`project_memory_summary\` orientation.",
          "enum": [
            "temporary",
            "permanent",
          ],
          "type": "string",
        },
        "limit": {
          "default": 5,
          "maximum": 20,
          "minimum": 1,
          "type": "integer",
        },
        "scope": {
          "default": "all",
          "enum": [
            "project",
            "global",
            "all",
          ],
          "type": "string",
        },
        "storedIn": {
          "default": "any",
          "description": "Filter by vault storage label like list tool.",
          "enum": [
            "project-vault",
            "main-vault",
            "any",
            "attached",
          ],
          "type": "string",
        },
      },
      "type": "object",
    },
    "name": "recent_memories",
    "outputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "recent_shown",
          "type": "string",
        },
        "count": {
          "type": "number",
        },
        "limit": {
          "type": "number",
        },
        "notes": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
              },
              "lifecycle": {
                "enum": [
                  "temporary",
                  "permanent",
                ],
                "type": "string",
              },
              "preview": {
                "type": "string",
              },
              "project": {
                "additionalProperties": false,
                "properties": {
                  "id": {
                    "type": "string",
                  },
                  "name": {
                    "type": "string",
                  },
                },
                "required": [
                  "id",
                  "name",
                ],
                "type": "object",
              },
              "tags": {
                "items": {
                  "type": "string",
                },
                "type": "array",
              },
              "title": {
