              "type": "string",
            },
            "pushBranch": {
              "type": "string",
            },
            "vaultFolder": {
              "type": "string",
            },
            "writable": {
              "type": "boolean",
            },
          },
          "required": [
            "projectSlug",
            "projectName",
            "localPath",
            "vaultFolder",
            "enabled",
            "branch",
            "branchTipHash",
          ],
          "type": "object",
        },
        "project": {
          "additionalProperties": false,
          "properties": {
            "id": {
              "type": "string",
            },
            "name": {
              "type": "string",
            },
          },
          "required": [
            "id",
            "name",
          ],
          "type": "object",
        },
        "retry": {
          "additionalProperties": false,
          "properties": {
            "attemptedCommit": {
              "additionalProperties": false,
              "properties": {
                "body": {
                  "type": "string",
                },
                "cwd": {
                  "type": "string",
                },
                "error": {
                  "type": "string",
                },
                "files": {
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
                "operation": {
                  "enum": [
                    "add",
                    "commit",
                  ],
                  "type": "string",
                },
                "subject": {
                  "type": "string",
                },
                "vault": {
                  "pattern": "^main-vault$|^project-vault$|^sub-vault:\\.mnemonic-.+$|^attached:[a-z0-9][-a-z0-9]*\\/\\.mnemonic(-.+)?$",
                  "type": "string",
                },
              },
              "required": [
                "subject",
                "files",
                "vault",
                "error",
              ],
              "type": "object",
            },
            "instructions": {
              "additionalProperties": false,
              "properties": {
                "forbidInferenceFromHistory": {
                  "type": "boolean",
                },
                "forbidInferenceFromTitleOrSummary": {
                  "type": "boolean",
                },
                "forbidParallelSameVaultRetries": {
                  "type": "boolean",
                },
                "preferToolReconciliation": {
                  "type": "boolean",
                },
                "rerunSameToolCallSerially": {
                  "type": "boolean",
                },
                "sourceOfTruth": {
                  "enum": [
                    "attemptedCommit",
                    "tool-response",
                  ],
                  "type": "string",
                },
                "useExactBody": {
                  "type": "boolean",
                },
                "useExactFiles": {
                  "type": "boolean",
                },
                "useExactSubject": {
                  "type": "boolean",
                },
